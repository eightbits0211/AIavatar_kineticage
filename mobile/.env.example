# Mobile environment variables (Expo inlines EXPO_PUBLIC_* at build time).
# Copy to mobile/.env and fill in the values. Do NOT commit mobile/.env.
#
# Firebase web app config — Firebase console → Project settings → Your apps → Web.
# These are not secret (they ship to clients) but are kept out of source control.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth client IDs — Google Cloud console → Credentials → OAuth client IDs.
# Web client ID is used by Expo Go / web; native client IDs for standalone builds.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
